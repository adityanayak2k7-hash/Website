{ 
  "name": "job-profile-website",
  "version": "1.0.0",
  "description": "A job profile website with a React frontend, Node.js backend, and MongoDB database",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "client": "npm start --prefix client",
    "dev": "concurrently "npm run server" "npm run client"",
    "server": "nodemon server.js"
  },
  "dependencies": {
    "express": "^4.17.1",
    "mongoose": "^5.11.15",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "concurrently": "^5.3.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.4"
  }
}